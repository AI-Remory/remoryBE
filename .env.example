# Remory backend environment
# 기준 파일: app/core/settings.py::Settings
# pydantic-settings는 extra=forbid 기본 동작을 사용하므로, 여기에 없는 키를 .env에 넣으면
# alembic current / alembic upgrade head / uvicorn 실행 시 ValidationError가 발생할 수 있다.

# App
# production/staging에서는 DEBUG=False로 둔다.
APP_NAME=Remory API
DEBUG=True
ENVIRONMENT=development

# Database
# production/staging에서는 localhost 대신 실제 DB host와 강한 비밀번호를 사용한다.
MYSQL_USER=remory
MYSQL_PASSWORD=change-me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=remory_db

# JWT
# production/staging에서는 반드시 긴 난수 문자열로 교체한다.
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS
# JSON 배열 문자열 형식으로 작성한다. production에서는 실제 frontend origin만 둔다.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
# 서버 프로세스가 쓰기 가능한 경로여야 한다.
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Gemini AI
# mock 없이 실제 AI 응답을 쓰려면 API key를 설정한다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Speech-to-Text
# 현재 서비스 코드는 mock provider를 기본값으로 사용한다.
STT_PROVIDER=mock
WHISPER_MODEL_SIZE=base

# Text-to-Speech
TTS_PROVIDER=mock

# Voice Cloning
VOICE_CLONE_PROVIDER=mock
# OpenVoice V2 runtime paths and behavior
OPENVOICE_CHECKPOINT_ROOT=./models/openvoice
OPENVOICE_CONVERTER_CONFIG_PATH=
OPENVOICE_CONVERTER_CHECKPOINT_PATH=
OPENVOICE_SOURCE_SE_PATH=
OPENVOICE_OUTPUT_DIR=./uploads/voices/openvoice
OPENVOICE_DEVICE=auto
OPENVOICE_WATERMARK_MESSAGE=@Remory
OPENVOICE_FAILOVER_TO_MOCK=False
OPENVOICE_BASE_SPEAKER=KR
OPENVOICE_TTS_LANGUAGE=KR
OPENVOICE_TTS_SPEED=1.0
# Deprecated: kept only for backward compatibility.
OPENVOICE_CHECKPOINT_PATH=
VOICE_SAMPLE_MIN_COUNT=1
VOICE_SAMPLE_MIN_TOTAL_DURATION_MS=100
VOICE_SAMPLE_MIN_FILE_SIZE_BYTES=1024
VOICE_PROFILE_MIN_QUALITY_SCORE=0.5

# Rate Limiting & Usage Limits
MONTHLY_USER_VOICE_GENERATION_LIMIT=1000
MONTHLY_PERSONA_VOICE_GENERATION_LIMIT=500
MONTHLY_USER_STT_REQUEST_LIMIT=500
MONTHLY_USER_VOICE_CALL_SECONDS_LIMIT=3600
RATE_LIMIT_REQUESTS_PER_MINUTE_DEFAULT=60
RATE_LIMIT_REQUESTS_PER_MINUTE_VOICE=10
VOICE_WS_MAX_ACTIVE_CONNECTIONS_PER_USER=2
VOICE_WS_MAX_UTTERANCES_PER_MINUTE=20
VOICE_WS_MAX_CHUNK_BYTES=262144
VOICE_WS_MAX_CHUNKS_PER_UTTERANCE=100
